<div class="taeller"><p id="count">0</p></div>

<script>
  let count = 3434346;

  setInterval(() => {
    count += 0.01;
    document.getElementById("count").innerText = count.toLocaleString("da-DK") + "Kr";
  }, 10);
</script>

<style>
  .taeller {
    /* margin-top: 100px; */
    background-color: var(--btn-color);
    width: 1300px;
    height: auto;
    padding-left: 20px;
    border-radius: 50px 50px 50px 50px;
    margin-bottom: 20px;
    box-shadow: 0px 5px 22px 5px rgba(0, 0, 0, 0.2);
  }

  @media (max-width: 880px) {
    #count {
      font-size: 50px;
      color: white;
      padding: 10px;
    }
  }

  @media (min-width: 880px) {
    #count {
      font-size: 120px;
      color: white;
      padding: 20px;
    }
  }
</style>
