<section class="info-text" id="infoPopup">
            <h2>Guide og information</h2>
            <article>
                <p class="placeholder">Click på en af hotspotsne</p>
            </article>
            <aside id="efficiency" class="info-box"></aside>
            <button id="closePopup">Luk</button>
</section>

<style>
    .info-text {
        min-width: 200px;
        box-shadow: 1px 2px 12px black;
    }
    
    @media (max-width: 880px) {

    .info-text {

        position: fixed;

        left: 0;

        width: 100%;
        height: 60vh;

        background: white;

        z-index: 1000;

        padding: 2rem;

        border-radius: 20px;

       opacity: 0;
       visibility: hidden;
    transform: translateY(20px);

    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
    }
    .info-text.active{
    opacity: 1;
    transform: translateY(0);
    visibility: visible;
}

</style>