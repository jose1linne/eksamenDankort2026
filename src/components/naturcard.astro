---
<section class="info-text" id="infoPopup">
            <h2>Guide og information</h2>
            <article>
                <p class="placeholder">Click på en af hotspotsne</p>
            </article>
            <aside id="efficiency" class="info-box"></aside>
            <button id="closePopup">Luk</button>
</section>

<style>
    .info-text {
    position: fixed;

    left: 0;
    bottom: 0;

    width: 100%;

    background: white;

    padding: 2rem;

    border-radius: 24px 24px 0 0;

    box-shadow: 0 -10px 30px rgba(0,0,0,0.2);

    z-index: 9999;

    opacity: 0;
    visibility: hidden;

    transform: translateY(100%);

    transition:
      opacity 0.3s ease,
      transform 0.3s ease,
      visibility 0.3s;
}

.info-text.active {
    opacity: 1;
    visibility: visible;

    transform: translateY(0);
}

.info-text img {
    border-radius: 12px;
    margin-top: 1rem;
}

#closePopup {
    margin-top: 1rem;
    display: block;
}
@media (min-width: 880px) {

.info-text {
    position: sticky;

    top: 100px;

    transform: none;
    opacity: 1;
    visibility: visible;

    border-radius: 20px;

    box-shadow: 1px 2px 12px rgba(0,0,0,0.15);

    height: fit-content;

    transition: none;

}

#closePopup {
    display: none;
}
}
</style>