---
---
<section class="info-text" id="infoPopup">
            <h2></h2>
            <article>
                <p class="placeholder">Klik på blomsterne for at læse mere om de områder Øremærket har doneret til</p>
            </article>
            <aside id="efficiency" class="info-box"></aside>
              <button id="closePopup" aria-label="Luk popup">
    &times;
</button>
</section>

<style>
    .info-text {
    position: fixed;

    left: 0;
    bottom: 0;

    width: 100%;

    background: white;

    padding: 2rem;

    border-radius: 24px 24px 0 0;

    box-shadow: 0 -10px 30px rgba(0,0,0,0.2);

    opacity: 0;
    visibility: hidden;

    transform: translateY(100%);

    transition:
      opacity 0.3s ease,
      transform 0.3s ease,
      visibility 0.3s;
}

.info-text.active {
    opacity: 1;
    visibility: visible;

    transform: translateY(0);
}

.info-text img {
    border-radius: 12px;
    margin-top: 1rem;
}

#closePopup {
    display: block;
    position: absolute;
    top: 1rem;
    right: 1rem;

    width: 30px;
    height: 30px;

    border: 2px solid var(--btn-color);
    border-radius: 50%;
    

    background: var(--primary-bg-color);
    color: var(--btn-color);

    font-size: 2rem;

    display: flex;
    align-items: center;
    justify-content: center;

    cursor: pointer;

    transition:
        background-color 0.25s ease,
        color 0.25s ease,
        transform 0.2s ease;
}

#closePopup:hover {
    background: var(--btn-color);
    color: var(--primary-bg-color);

    transform: scale(1.05);
    border: none;
}

@media (min-width: 880px) {

.info-text {

position: relative;

    transform: none;
    opacity: 1;
    visibility: visible;

    border-radius: 20px;

    box-shadow: 0px 0px 0px;

    width: 100%;
    height: 100%;

    transition: none;

}
}
</style>