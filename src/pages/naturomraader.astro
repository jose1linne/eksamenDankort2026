</Layout>

<style>
main{
    display: grid;
    grid-template-columns: 5fr 3fr;
}
#Hotspots path {
    fill: #DE2229;
    cursor: pointer;
    stroke: transparent;
    stroke-width: 10;
}

#Hotspots path:hover {
    fill: white;
    filter: drop-shadow(10 10 10px #ff00f7);
}
</style>
<script define:vars={{ data }}>

const overskrift = document.querySelector(".info-text h2");
const underrubrik = document.querySelector(".placeholder");
const billede = document.querySelector(".info-box");


// Finder ALLE hotspots
const hotspots = document.querySelectorAll("#Hotspots path");


// Loop gennem alle hotspots
hotspots.forEach((spot) => {

    spot.addEventListener("click", () => {
const infoPopup = document.querySelector("#infoPopup");
        // Finder matchende objekt i API
        const område = data.find(
            item => item.id == spot.id
        );

        console.log(område);

        // Indsætter data
        overskrift.textContent = område.title;

        underrubrik.textContent = område.description;

        billede.innerHTML = `
            <img src="${område.image}" alt="${område.title}">
        `;
infoPopup.classList.add("active");
    });

});
const closePopup = document.querySelector("#closePopup");

closePopup.addEventListener("click", () => {
    infoPopup.classList.remove("active");
});
</script>